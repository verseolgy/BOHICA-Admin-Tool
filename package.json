{
  "name": "bohica-admin-tool",
  "version": "1.0.0",
  "description": "BOHICA Admin Tool - Ark Dino Spawner",
  "main": "main.js",
  "homepage": "./",
  "author": "verseolgy",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-exe": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "31.0.0",
    "electron-builder": "24.9.1"
  },
  "build": {
    "appId": "com.bohica.admintool",
    "productName": "BOHICA Admin Tool",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "script.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
